{
  "name": "a1-localization-am",
  "version": "1.0.0",
  "description": "Armenian (RA) localization + fiscal engines — ՀՎՀՀ/AMD kernel, marz + phone dictionaries, 623-account chart of accounts, SRC e-invoice XML, VAT return (decree N 298-Ն), and 2026 payroll. Zero runtime dependencies.",
  "main": "index.js",
  "bin": {
    "ra-localization": "scripts/ra-localization.js"
  },
  "scripts": {
    "test": "node --test --test-concurrency=4 --test-timeout=60000",
    "karpathy:list": "node scripts/karpathy-eval.mjs --list",
    "karpathy:program": "node scripts/karpathy-eval.mjs --program",
    "karpathy:run": "node scripts/karpathy-eval.mjs --run"
  },
  "files": [
    "index.js",
    "src/",
    "scripts/"
  ],
  "keywords": [
    "armenia",
    "armenian",
    "localization",
    "l10n",
    "fiscal",
    "tax",
    "vat",
    "payroll",
    "e-invoice",
    "hvhh",
    "amd",
    "chart-of-accounts",
    "ra"
  ],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@a1/ai": "https://github.com/Armosphera/A1-AI-Core/archive/f6c57a2c0ba0ceca7a6de880f03ed05a305bab5d.tar.gz"
  },
  "license": "UNLICENSED",
  "private": true
}
